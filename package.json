{
  "name": "multipost",
  "displayName": "MultiPost - WeChat Publisher",
  "description": "Publish Markdown directly to WeChat Official Accounts from VSCode",
  "version": "0.5.8",
  "publisher": "cygnus",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/cygnus/MultiPost.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:multipost.configurePublishOptions",
    "onCommand:multipost.preview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "MultiPost",
      "properties": {
        "wechatPublisher.defaultAuthor": {
          "type": "string",
          "default": "",
          "description": "Default author name used when creating a WeChat draft."
        },
        "wechatPublisher.digestLength": {
          "type": "number",
          "default": 120,
          "minimum": 0,
          "description": "Digest length extracted from markdown content."
        },
        "wechatPublisher.declareOriginal": {
          "type": "boolean",
          "default": true,
          "description": "Enable original declaration by default."
        },
        "wechatPublisher.enableAppreciation": {
          "type": "boolean",
          "default": true,
          "description": "Enable appreciation by default."
        },
        "wechatPublisher.defaultCollection": {
          "type": "string",
          "default": "智能体",
          "description": "Default collection name used in WeChat."
        },
        "wechatPublisher.publishDirectly": {
          "type": "boolean",
          "default": true,
          "description": "Publish directly by default; disable to save as draft."
        },
        "wechatPublisher.contentThemePreset": {
          "type": "string",
          "enum": [
            "classic",
            "magazine",
            "minimal"
          ],
          "default": "classic",
          "description": "Theme preset for article typography and layout."
        },
        "wechatPublisher.contentBodyFontSize": {
          "type": "number",
          "default": 16,
          "minimum": 12,
          "maximum": 22,
          "description": "Body text font size for uploaded article content."
        },
        "wechatPublisher.contentLineHeight": {
          "type": "number",
          "default": 1.85,
          "minimum": 1.2,
          "maximum": 2.4,
          "description": "Body text line height for uploaded article content."
        },
        "wechatPublisher.contentTextColor": {
          "type": "string",
          "default": "#1f2329",
          "description": "Body text color (HEX) for uploaded article content."
        },
        "wechatPublisher.contentHeadingColor": {
          "type": "string",
          "default": "#0f172a",
          "description": "Heading color (HEX) for uploaded article content."
        },
        "wechatPublisher.contentLinkColor": {
          "type": "string",
          "default": "#0969da",
          "description": "Link/accent color (HEX) for uploaded article content."
        }
      }
    },
    "commands": [
      {
        "command": "multipost.uploadToWeChat",
        "title": "Upload to WeChat Official Accounts (Playwright)",
        "icon": {
          "light": "media/icons/upload-light.svg",
          "dark": "media/icons/upload-dark.svg"
        }
      },
      {
        "command": "multipost.logoutWeChat",
        "title": "Logout MultiPost"
      },
      {
        "command": "multipost.configurePublishOptions",
        "title": "Configure MultiPost Publish Options"
      },
      {
        "command": "multipost.preview",
        "title": "Preview MultiPost Format"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=json-summary",
    "playwright:install": "playwright install",
    "test:playwright": "playwright test",
    "playwright:codegen": "playwright codegen"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "jest": "^30.3.0",
    "markdown-it": "^14.1.0",
    "playwright": "^1.59.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
