# Node dependencies - vsce will automatically exclude devDependencies
node_modules/

# TypeScript source files - we only need the compiled output
src/**
!out/**
out/**/*.js.map
tsconfig.tsbuildinfo

# Test files and results
src/test/**
test-results/**
coverage/**
playwright-profile/**

# Development tools and configs
.kilo/**
.github/**
.vscode/**
!.vscode/extensions.json
.git/**
.gitignore
tsconfig.json
tsconfig.test.json
jest.config.js
.eslintrc*
.prettierrc*

# Documentation
docs/**
TESTING.md
INSTALL.md
CHANGELOG.md

# Temporary files
*.vsix
*.log
.DS_Store
Thumbs.db
.env
.env.local
*.local

# Temporary development files
checkWeChatLoggedInPage.js
checkWeChatPageStructure.ts
playwright-wechat.py
test-markdown.js
image/
scripts/
