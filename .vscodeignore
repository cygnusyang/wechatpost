# Node dependencies
# Don't exclude entire node_modules - we need all production dependencies for require to work
# Only exclude unnecessary parts
node_modules/.cache/**
node_modules/*/node_modules/**
node_modules/*/test/**
node_modules/*/tests/**
node_modules/*/*.md
node_modules/*/*.yml
node_modules/*/*.yaml
# Keep all production dependencies (including canvas, node-fetch, etc.)
!node_modules/**

# Out of directory
src/**
!out/**
# Wait, we do need the compiled output in out/
out/**/*.js.map

# VSIX shouldn't be included
*.vsix

# Development
.vscode
.git
.github
coverage
docs
*.log

# webview source
webview-src/**
!webview-src/dist/**

# TypeScript source
*.ts
!out/**/*.js

# Testing
**/*.test.ts
**/*.test.js
src/test/**/__mocks__/**

# Environment
.env
.env.local
*.local.json

# Coverage
coverage

# NPM
.npmrc
.npmignore
