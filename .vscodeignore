# Node dependencies
# Exclude all node_modules - VSCode extensions don't need them
node_modules/**

# Development tools
.kilo/**

# TypeScript build cache
tsconfig.tsbuildinfo

# Test files and results
checkWeChatLoggedInPage.js
playwright-wechat.py
test-results/**

# Out of directory
src/**
!out/**
# Wait, we do need the compiled output in out/
out/**/*.js.map

# VSIX shouldn't be included
*.vsix

# Development
.vscode
.git
.github
coverage
docs
*.log

# webview source
webview-src/**
!webview-src/dist/**

# TypeScript source
*.ts
!out/**/*.js

# Testing
**/*.test.ts
**/*.test.js
src/test/**/__mocks__/**

# Environment
.env
.env.local
*.local.json

# Coverage
coverage

# NPM
.npmrc
.npmignore
